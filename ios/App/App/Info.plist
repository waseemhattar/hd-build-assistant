<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
<key>CFBundleURLTypes</key>
<array>
    <dict>
        <key>CFBundleURLSchemes</key>
        <array>
            <string>com.googleusercontent.apps.840227267450-abot6d3srrj0pko9jan8ltg23mvgulh9</string>
        </array>
    </dict>
</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Sidestand</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Sidestand uses your location to record GPS-tracked rides.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Sidestand records your ride in the background so you can put your phone away and ride.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Sidestand records your ride in the background so you can put your phone away and ride.</string>
	<key>NSCameraUsageDescription</key>
	<string>Sidestand uses your camera to scan VIN barcodes when adding a bike, capture cover photos, and let you show the AI mechanic a part for identification.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Sidestand reads photos from your library so you can attach part images and bike cover photos.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Sidestand may save processed images of your parts and rides to your photo library if you choose.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Sidestand may record a short voice note alongside ride photos. Disable this in Settings if you don't want microphone access.</string>
	<!--
	  Background modes. We declare ONLY `location` because the
	  RideTracker keeps GPS recording when the rider locks the
	  screen and rides. We do NOT use background audio (Apple
	  rejected 1.0 for declaring it without a justifying feature —
	  background audio is for music players / podcast apps that
	  keep playing when the screen locks). Microphone use is
	  foreground-only (ride voice notes), which doesn't need a
	  background mode.
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
	<!--
	  Export-compliance flag. Sidestand uses encryption only via iOS's
	  built-in networking stack (HTTPS / TLS) — we don't ship custom
	  crypto code or bundle a third-party crypto library. Setting this
	  to <false/> tells Apple at build time that we're exempt from
	  export-compliance documentation under the EAR §740.17 mass-market
	  exemption, which means App Store Connect skips the "App Encryption
	  Documentation" dialog on every future build upload.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
