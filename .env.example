# Copy this to .env.local and fill in your real values.
# .env.local is gitignored — don't commit secrets.

# Clerk (auth) — get this from https://dashboard.clerk.com → your app → API Keys
# The publishable key is safe to expose in the browser. The secret key is NOT — never put it here.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Stadia Maps — optional. Unlocks the "Dark map" and "Satellite" share-card
# templates by fetching real tiles for the route background. If unset, only
# the silhouette template is offered. Free tier (200K credits/month) is more
# than enough for a small app. Sign up at https://client.stadiamaps.com/.
VITE_STADIA_API_KEY=
