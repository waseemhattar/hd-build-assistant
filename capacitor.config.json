{
  "appId": "app.sidestand.app",
  "appName": "Sidestand",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0E0E10"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0E0E10",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0E0E10",
      "overlaysWebView": false
    }
  },
  "server": {
    "url": "https://sidestand.app",
    "cleartext": false,
    "allowNavigation": [
      "sidestand.app",
      "*.sidestand.app",
      "accounts.google.com",
      "*.google.com",
      "login.microsoftonline.com",
      "appleid.apple.com",
      "*.apple.com"
    ]
  }
}
