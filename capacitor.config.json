{
  "appId": "app.sidestand.app",
  "appName": "Sidestand",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0E0E10"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0E0E10",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0E0E10",
      "overlaysWebView": false
    },
    "BackgroundGeolocation": {
      "notificationTitle": "Sidestand is recording your ride",
      "notificationText": "Tap to return to the app",
      "backgroundMessage": "Recording GPS in the background",
      "backgroundTitle": "Sidestand",
      "requestPermissions": true,
      "stale": false,
      "distanceFilter": 5
    }
  },
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor",
    "hostname": "localhost",
    "cleartext": false,
    "allowNavigation": [
      "sidestand.app",
      "*.sidestand.app",
      "*.supabase.co",
      "accounts.google.com",
      "*.google.com",
      "appleid.apple.com",
      "*.apple.com"
    ]
  }
}
