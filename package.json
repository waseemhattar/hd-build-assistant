{
  "name": "sidestand",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Sidestand — build assistant for motorcycle riders. Track service, log mods, follow step-by-step procedures, share your build.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "ingest:jobs": "node scripts/ingest-jobs.mjs",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npm run build && npx cap sync ios && npx cap open ios",
    "ios:run": "npm run build && npx cap sync ios && npx cap run ios"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.21",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capgo/capacitor-social-login": "^7.20.0",
    "@supabase/supabase-js": "^2.45.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  }
}
